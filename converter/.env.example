# Copy this file to .env and adjust paths for your machine.
# .env is gitignored — personal config only.

# Path to Revit Family Templates directory.
# Typical location for Revit 2025 on Windows:
REVIT_TEMPLATES_DIR=C:\ProgramData\Autodesk\RVT 2025\Family Templates\English

# Revit version (affects API calls in some places)
REVIT_VERSION=2025

# Output directory for generated .rfa files
BIM_AI_OUTPUT_DIR=C:\Users\<you>\Documents\bim_ai_output